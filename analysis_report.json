  "alignments": {
    "legge_1861": [
      {
        "source_indices": [
          0
        ],
        "target_indices": [
          0
        ],
        "source_text": "学而时习之，不亦说乎？",
        "target_text": "Is it not pleasant to learn with constant practice?",
        "method": "fallback_dp_length_ratio"
      },
      {
        "source_indices": [
          1,
          2
        ],
        "target_indices": [
          1,
          2
        ],
        "source_text": "有朋自远方来，不亦乐乎？ 人不知而不愠，不亦君子乎？",
        "target_text": "Is it not delightful to have friends coming from distant quarters? Is he not a superior man, who feels no discomposure though men may take no note of him?",
        "method": "fallback_dp_length_ratio"
      },
      {
        "source_indices": [
          3,
          4
        ],
        "target_indices": [
          3,
          4
        ],
        "source_text": "君子喻于义，小人喻于利。 仁者安仁，知者利仁。",
        "target_text": "The superior man understands righteousness; the mean man understands profit. The man of perfect virtue rests in benevolence, and the wise value benevolence.",
        "method": "fallback_dp_length_ratio"
      }
    ],
    "ku_huang_1998": [
      {
        "source_indices": [
          0,
          1
        ],
        "target_indices": [
          0,
          1
        ],
        "source_text": "学而时习之，不亦说乎？ 有朋自远方来，不亦乐乎？",
        "target_text": "To learn and at due times repeat what one has learnt, is that not after all a pleasure? To have friends come from afar, is that not a joy?",
        "method": "fallback_dp_length_ratio"
      },
      {
        "source_indices": [
          2
        ],
        "target_indices": [
          2
        ],
        "source_text": "人不知而不愠，不亦君子乎？",
        "target_text": "To remain unvexed when others do not know you, is that not the mark of a gentleman?",
        "method": "fallback_dp_length_ratio"
      },
      {
        "source_indices": [
          3,
          4
        ],
        "target_indices": [
          3,
          4
        ],
        "source_text": "君子喻于义，小人喻于利。 仁者安仁，知者利仁。",
        "target_text": "A gentleman understands duty; a small man understands gain. The humane man is at home in humanity, and the wise profit by humanity.",
        "method": "fallback_dp_length_ratio"
      }
    ],
    "lau_1979": [
      {
        "source_indices": [
          0,
          1
        ],
        "target_indices": [
          0,
          1
        ],
        "source_text": "学而时习之，不亦说乎？ 有朋自远方来，不亦乐乎？",
        "target_text": "To learn and to practise what is learned from time to time, is this not a pleasure? To have friends come from afar, is this not a joy?",
        "method": "fallback_dp_length_ratio"
      },
      {
        "source_indices": [
          2
        ],
        "target_indices": [
          2
        ],
        "source_text": "人不知而不愠，不亦君子乎？",
        "target_text": "To remain unsoured even though others do not recognize you, is this not to be a gentleman?",
        "method": "fallback_dp_length_ratio"
      },
      {
        "source_indices": [
          3,
          4
        ],
        "target_indices": [
          3,
          4
        ],
        "source_text": "君子喻于义，小人喻于利。 仁者安仁，知者利仁。",
        "target_text": "The gentleman understands what is right; the petty man understands profit. The benevolent man finds peace in benevolence; the wise make use of benevolence.",
        "method": "fallback_dp_length_ratio"
      }
    ]
  },
